{{ if eq .chezmoi.os "darwin" -}}
[plugins]
flutter = "https://github.com/mise-plugins/mise-flutter.git"
{{ end -}}

[settings.status]
show_env = true
show_tools = false

[tools]
{{/* 言語ランタイム は skip_cli_tools=false を明示した環境でのみ入れる */ -}}
{{/* / クラウド CLIは、macos かつ skip_cli_tools=false の環境でのみ入れる */ -}}
{{ if and (eq .chezmoi.os "darwin") (not (dig "skip_cli_tools" true .)) -}}
awscli = "2.35.11"
aws-sso = "2.3.1"
{{ end -}}
direnv = "2.37.1"
{{ if and (eq .chezmoi.os "darwin") (not (dig "skip_cli_tools" true .)) -}}
flutter = "3.44.4-stable"
{{ end -}}
fzf = "0.73.1"
{{ if and (eq .chezmoi.os "darwin") (not (dig "skip_cli_tools" true .)) -}}
gcloud = "574.0.0"
{{ end -}}
ghq = "1.10.1"
{{ if not (dig "skip_cli_tools" true .) -}}
go = "1.26.4"
java = "temurin-26.0.1+8"
{{ end -}}
{{ if and (eq .chezmoi.os "darwin") (not (dig "skip_cli_tools" true .)) -}}
kubectl = "1.36.2"
{{ end -}}
{{ if not (dig "skip_cli_tools" true .) -}}


{{ end -}}
peco = "0.6.0"
starship = "1.26.0"
{{ if and (eq .chezmoi.os "darwin") (not (dig "skip_cli_tools" true .)) -}}
stern = "1.34.0"
terraform = "1.15.7"
terragrunt = "1.0.8"
{{ end -}}
{{/* CLI ユーティリティ群。最小構成 (skip_cli_tools=true) では省く。 */ -}}
{{ if not (dig "skip_cli_tools" false .) -}}
age = "1.3.1"
bat = "0.26.1"
bats = "1.13.0"
duf = "0.9.1"
dust = "1.2.4"
eza = "0.23.4"
fastfetch = "2.65.2"
fd = "10.4.2"
fnox = "1.29.0"
gh = "2.95.0"
glab = "1.106.0"
git-lfs = "3.7.1"
hadolint = "2.14.0"
hexyl = "0.17.0"
jq = "1.8.2"
op = "2.34.1"
prek = "0.4.8"
ripgrep = "15.1.0"
ruff = "0.15.20"
shellcheck = "0.11.0"
tmux = "3.7b"
ty = "0.0.56"
usage = "3.5.4"
uv = "0.11.25"
websocat = "1.14.1"
yq = "4.53.3"
zoxide = "0.10.0"
"ubi:boyter/scc" = "3.7.0"
"ubi:dalance/procs" = "0.14.12"
"go:github.com/cloudflare/cloudflare-go/cmd/flarectl" = "0.117.0"
{{ end -}}
