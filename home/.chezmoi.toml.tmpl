{{/* age 暗号化。単一共有鍵。$ageRecipient が空の間は暗号化機能は無効 (scaffold 状態) */ -}}
{{- $ageRecipient := "age100fze4m9k88fyzpg2z5l2hfmk9f299mzl63sjz3s9gk0s8hkt94smeccd0" }}
{{- if $ageRecipient }}
encryption = "age"
[age]
    identity = {{ (joinPath .chezmoi.homeDir ".config" "chezmoi" "key.txt") | quote }}
    recipient = {{ $ageRecipient | quote }}
{{ end }}
[git]
autoCommit = true
autoPush = true

{{ if eq .chezmoi.os "windows" -}}
# chezmoi の既定は pwsh 優先 (無ければ powershell にフォールバック) のため、
# pwsh の有無で .ps1 スクリプトの実行ホストが変わらないよう、標準搭載の
# Windows PowerShell 5.1 に固定する (スクリプトは 5.1 互換で書かれている)。
# -NoProfile: プロファイル (starship 初期化等) をスクリプト実行のたびに読ませない。
# -ExecutionPolicy Bypass: 既定が Restricted のマシンでも apply が失敗しないようにする。
[interpreters.ps1]
command = "powershell"
args = ["-NoLogo", "-NoProfile", "-ExecutionPolicy", "Bypass"]

{{ end -}}
[data]
{{- if eq .chezmoi.os "darwin" }}
# mac OS specific configuration
{{-   $current := output "sh" "-c" "name=$(scutil --get ComputerName 2>/dev/null || true); echo \"current computer_name: $name\" >&2; printf '%s' \"$name\"" | trim }}
{{-   $model := output "sh" "-c" "system_profiler SPHardwareDataType | awk -F': ' '/Model Name/ { print $2 }'" | trim }}
{{-   $computerName := "" }}
{{-   if eq $model "MacBook Pro" }}
{{-     $computerName = promptStringOnce . "computer_name" "e.g.: MacBookPro***-<user>" }}
{{-   else if eq $model "MacBook Air" }}
{{-     $computerName = promptStringOnce . "computer_name" "e.g.: MacBookAir***-<user>" }}
{{-   else }}
{{-     $computerName = promptStringOnce . "computer_name" "e.g.: Mac***-<user>" }}
{{-   end }}
computer_name = {{ $computerName | quote }}
{{- end }}

{{ $skipCliTools := false -}}
{{- if ne .chezmoi.os "windows" }}
{{-   $skipCliTools = promptBoolOnce . "skip_cli_tools" "Skip CLI tool installation? (default: yes)" true }}
skip_cli_tools = {{ $skipCliTools }}
{{-   $skipGuiTools := true }}
{{-   if not $skipCliTools }}
{{-     $skipGuiTools = promptBoolOnce . "skip_gui_tools" "Skip GUI tool installation? (default: yes)" true }}
{{-   end }}
skip_gui_tools = {{ $skipGuiTools }}
{{- end }}

{{ $skipWindowsExtras := false -}}
{{- if eq .chezmoi.os "windows" }}
# Windows specific configuration
{{-   $skipWindowsExtras = promptBoolOnce . "skip_windows_extras" "Skip coding agent / GUI apps / system settings setup? (default: yes)" true }}
skip_windows_extras = {{ $skipWindowsExtras }}
{{- end }}

{{- if and (not $skipCliTools) (not $skipWindowsExtras) }}
[data.apiKeys]
# API keys are injected by fnox. Missing env values intentionally expand to
# empty strings so the first bootstrap run can install fnox/1Password.
gemini = {{ env "GEMINI_API_KEY" | quote }}
googleMaps = {{ env "GOOGLE_MAP_API_KEY" | quote }}
fugu = {{ env "FUGU_API_KEY" | quote }}
openRouter = {{ env "OPENROUTER_API_KEY" | quote }}
{{- end }}
