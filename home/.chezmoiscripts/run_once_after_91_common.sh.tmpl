{{ if ne .chezmoi.os "windows" -}}
#!/bin/bash
set -e

{{ if eq .chezmoi.os "linux" -}}
{{   if or (eq .chezmoi.osRelease.id "debian") (eq (dig "idLike" "" .chezmoi.osRelease) "debian") -}}
export PATH="$HOME/.local/bin:$HOME/Works/bin:$PATH"
{{   end -}}
{{ end -}}
{{ if eq .chezmoi.os "darwin" -}}
eval "$(/opt/homebrew/bin/brew shellenv)"
{{ end -}}

export CHEZMOI_SOURCE_DIR="{{ .chezmoi.sourceDir }}"

# 各 install スクリプトは色変数や main などの名前が重複するため subshell で隔離する。
# ファイル間で必要な環境変数 (mise / cargo の PATH) は親で明示的に引き継ぐ。
(
{{   include "../install/common/setup_shell.sh" }}
)
# フォントの描画はクライアント側 (端末エミュレータ) で行われるため、ヘッドレス環境
# (Docker・CLI のみのサーバー等) では不要。GUI レスを表す skip_gui_tools=true なら
# スキップする。サーバー上で画像/PDF 等のラスタライズをする場合は別途明示的に入れる。
# macOS は skip_gui_tools 未定義のため dig の既定値 false でフォールバックする。
{{ if not (dig "skip_gui_tools" false .) -}}
(
{{   include "../install/common/fonts.sh" }}
)
{{ end -}}
(
{{   include "../install/common/mise.sh" }}
)
eval "$(mise activate bash --shims)"
{{ if not (dig "skip_cli_tools" false .) -}}
(
{{   include "../install/common/uv.sh" }}
)
{{ end -}}
(
{{   include "../install/common/fisher.sh" }}
)
{{ if not (dig "skip_cli_tools" false .) -}}
(
{{   include "../install/common/rust.sh" }}
)
# rust (cargo) で導入したツールを後続の completions から参照できるようにする
export PATH="$HOME/.cargo/bin:$PATH"
{{ end -}}
(
{{   include "../install/common/completions.sh" }}
)
{{ if not (dig "skip_cli_tools" false .) -}}
(
{{   include "../install/common/git_open.sh" }}
)
(
{{   include "../install/common/git_secrets.sh" }}
)
{{ end -}}
{{ if not (dig "skip_gui_tools" false .) -}}
(
{{   include "../install/common/ghostty.sh" }}
)
{{ end -}}

{{ if eq .chezmoi.os "darwin" -}}
if [ -z "${CI:-}" ]; then
  mo optimize
  mo clean
fi
{{ end -}}

# fish の設定ファイルのキャッシュを削除する
rm -f "$HOME/.cache/fish/config.fish"
{{ end -}}
