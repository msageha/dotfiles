{
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"]
    },
    "maps-grounding-lite-mcp": {
      "serverUrl": "https://mapstools.googleapis.com/mcp",
      "headers": {
        "X-Goog-Api-Key": "{{ dig "apiKeys" "googleMaps" "" . }}"
      }
    }
  }
}
