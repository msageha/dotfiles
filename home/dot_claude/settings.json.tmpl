    "ask": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(secrets/**)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "CMD=$(cat | jq -r '.tool_input.command'); if printf '%s\\n' \"$CMD\" | grep -qiE '(^|[;&|(])[[:space:]]*(sudo[[:space:]]+)?(rm[[:space:]]+-[[:alpha:]]*r[[:alpha:]]*[[:space:]]+(/|~|\\*|\\.([[:space:]]|$))|git[[:space:]]+reset[[:space:]]+--hard|git[[:space:]]+push[[:space:]].*--force([^-]|$)|chmod[[:space:]]+(-r[[:space:]]+)?(777|000)([[:space:]]|/|$)|killall[[:space:]]+(finder|dock|systemuiserver|windowserver|loginwindow|kernel_task|launchd|cfprefsd)|(mysql|psql|mariadb|sqlite3|mysqlsh)[[:space:]].*drop[[:space:]]+table)' ; then echo \"BLOCKED: Dangerous command: $CMD\" >&2; exit 2; fi",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cat | jq -c '{timestamp: (now | todate), command: .tool_input.command}' >> ~/.claude/command-audit.log",
            "async": true,
            "timeout": 5
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -n \"$TMUX_PANE\" ]; then ROLE=$(tmux display-message -t \"$TMUX_PANE\" -p '#{@role}' 2>/dev/null); if [ \"$ROLE\" = \"planner\" ] || [ \"$ROLE\" = \"worker\" ]; then exit 0; fi; fi; osascript -e 'display notification \"Claude Code が入力待ちです\" with title \"Claude Code\" sound name \"Glass\"'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -x .claude/verify.sh ]; then bash .claude/verify.sh; fi",
            "timeout": 600
          }
        ]
      }
    ]
  }
}
