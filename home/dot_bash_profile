# --- エイリアスの読み込み ---
if [ -f "$HOME/.alias" ]; then
    source "$HOME/.alias"
fi

# --- ヒストリーファイルの設定 ---
export HISTFILE="$HOME/.local/state/bash_history"
export NODE_REPL_HISTORY="$HOME/.local/state/node_repl_history"
export SQL_HISTORY="$HOME/.local/state/sql_history"
export MYSQL_HISTFILE="$HOME/.local/state/mysql_history"
export PSQL_HISTFILE="$HOME/.local/state/psql_history"
export PYTHON_HISTORY="$HOME/.local/state/python_history"

# --- PATH: ツール置き場を先に通す ---
# brew/mise/direnv/starship などの activate は PATH が揃っている前提のため、
# それらより前に静的なバイナリ置き場を PATH へ追加しておく。
# (uvでインストールしたツールや mise 本体は ~/.local/bin にある)
if [ -d "$HOME/.local/bin" ]; then
    export PATH="$HOME/.local/bin:$PATH"
fi

# --- Homebrewの設定 ---
_brew_bin="$(command -v brew || true)"
if [ -z "$_brew_bin" ] && [ -x /opt/homebrew/bin/brew ]; then
    _brew_bin="/opt/homebrew/bin/brew"
elif [ -z "$_brew_bin" ] && [ -x /usr/local/bin/brew ]; then
    _brew_bin="/usr/local/bin/brew"
fi
if [ -n "$_brew_bin" ]; then
    eval "$("$_brew_bin" shellenv)"
fi
unset _brew_bin

# --- Goの設定 ---
export GOPATH="$HOME/Works"
if [ -d "$HOME/Works/bin" ]; then
    export PATH="$HOME/Works/bin:$PATH"
fi

# --- JDKの設定 ---
if [ -f /opt/homebrew/opt/openjdk/bin/java ]; then
    export PATH="/opt/homebrew/opt/openjdk/bin:$PATH"
    export CPPFLAGS="-I/opt/homebrew/opt/openjdk/include" # Cプリプロセッサ用フラグ
fi

# --- Google Cloud SDKのPython設定 ---
export CLOUDSDK_PYTHON="$(command -v python3)"

# --- Docker環境設定 --- (Docker内で動作している場合に設定)
if [ -e /.dockerenv ] && [ -z "$DOCKER_MACHINE_NAME" ]; then
    export DOCKER_MACHINE_NAME="docker"
fi

# --- MySQLクライアントのパス追加 ---
if [ -d "/opt/homebrew/opt/mysql-client/bin/" ]; then
    export MYSQL_CLIENT_PATH="/opt/homebrew/opt/mysql-client"
    export PATH="$MYSQL_CLIENT_PATH/bin:$PATH"
fi

# --- mysqlclient用のコンパイラフラグ設定（macOSのみ） ---
if [[ "$(uname)" == "Darwin" ]]; then
    [[ "$PKG_CONFIG_PATH" != */opt/homebrew/lib/pkgconfig* ]] && export PKG_CONFIG_PATH="/opt/homebrew/lib/pkgconfig:$PKG_CONFIG_PATH"
    [[ "$LDFLAGS" != *-L/opt/homebrew/lib* ]] && export LDFLAGS="-L/opt/homebrew/lib $LDFLAGS"
    [[ "$CPPFLAGS" != *-I/opt/homebrew/include* ]] && export CPPFLAGS="-I/opt/homebrew/include $CPPFLAGS"
fi

# --- orbstackの設定 ---
if [ -d "$HOME/.orbstack/shell" ]; then
    source "$HOME/.orbstack/shell/init.bash"
fi

# --- Starshipの設定 ---
if command -v starship &>/dev/null; then
    eval "$(starship init bash)"
fi

# --- Xcodeの設定 ---
if xcode-select -p &>/dev/null; then
    export DEVELOPER_DIR="$(xcode-select -p)"
    # usr/bin は末尾に追加して Homebrew の git/python3 を優先しつつ simctl 等も引けるようにする
    export PATH="$PATH:$DEVELOPER_DIR/usr/bin"
fi

# --- direnvのフック設定 ---
_direnv_bin="$(command -v direnv || true)"
if [ -z "$_direnv_bin" ] && command -v mise &>/dev/null; then
    _direnv_bin="$(mise which direnv 2>/dev/null || true)"
fi
if [ -n "$_direnv_bin" ]; then
    eval "$("$_direnv_bin" hook bash)"
fi
unset _direnv_bin

# --- miseの初期化 ---
if command -v mise &>/dev/null; then
    eval "$(mise activate bash)"
fi

# --- 1Password CLI のデフォルトアカウント ---
export OP_ACCOUNT=my.1password.com

# --- fnoxの初期化 ---
if command -v fnox &>/dev/null; then
    eval "$(fnox activate bash)"
    _fnox_find_1password_config() {
        local dir="$PWD"
        while [ "$dir" != "/" ]; do
            for _fnox_config in "$dir"/fnox.toml "$dir"/fnox.local.toml "$dir"/fnox."${FNOX_PROFILE:-default}".toml; do
                [ -f "$_fnox_config" ] || continue
                if grep -Eq 'type[[:space:]]*=[[:space:]]*["'\'']1password["'\'']' "$_fnox_config"; then
                    printf '%s\n' "$_fnox_config"
                    return 0
                fi
            done
            dir="${dir%/*}"
            [ -n "$dir" ] || dir="/"
        done
        return 1
    }

    _fnox_preauth_1password() {
        command -v op &>/dev/null || return 0

        local config_path
        config_path="$(_fnox_find_1password_config)" || return 0

        op whoami >/dev/null 2>&1 && return 0
        [ "${__FNOX_1PASSWORD_PREAUTH_FAILED_FOR:-}" = "$config_path" ] && return 1

        if op signin >/dev/null 2>&1; then
            unset __FNOX_1PASSWORD_PREAUTH_FAILED_FOR
            return 0
        fi
        export __FNOX_1PASSWORD_PREAUTH_FAILED_FOR="$config_path"
        return 1
    }

    _fnox_hook() {
        local previous_exit_status=$?
        trap -- '' SIGINT
        if _fnox_preauth_1password; then
            eval "$(command fnox hook-env -s bash)"
        else
            eval "$(FNOX_PROMPT_AUTH=false command fnox hook-env -s bash)"
        fi
        trap - SIGINT
        return $previous_exit_status
    }
fi

# --- AWS CLI / aws-sso-cli の補完初期化 ---
# aws-sso の補完は aws-sso-profile 等のヘルパー関数も含むため、後述の
# completions.sh 生成ファイル群のループには乗せず、この場で直接 source する。
if command -v aws_completer &>/dev/null; then
    complete -C aws_completer aws
fi
if command -v aws-sso &>/dev/null; then
    eval "$(aws-sso setup completions --source --shell bash)"
fi

# --- GitHub トークンの動的注入 ---
# GitHub MCP server (Claude Code の github plugin) が参照する。gh の OAuth トークンを
# 都度取得することで PAT をファイルに置かない。gh 未導入・未ログイン時は設定しない。
if [ -z "$GITHUB_PERSONAL_ACCESS_TOKEN" ] && command -v gh &>/dev/null; then
    _gh_token="$(gh auth token 2>/dev/null)"
    if [ -n "$_gh_token" ]; then
        export GITHUB_PERSONAL_ACCESS_TOKEN="$_gh_token"
    fi
    unset _gh_token
fi

# --- 補完の読み込み ---
# completions.sh が生成した静的ファイル (kubectl/ngrok/uv 含む) を source する
_bash_completions_dir="$HOME/.local/share/bash-completion/completions"
if [ -d "$_bash_completions_dir" ]; then
    _bash_supports_usage_completion=false
    if ((BASH_VERSINFO[0] > 4 || (BASH_VERSINFO[0] == 4 && BASH_VERSINFO[1] >= 2))); then
        _bash_supports_usage_completion=true
    fi

    if $_bash_supports_usage_completion && [ -r "$_bash_completions_dir/mise" ]; then
        source "$_bash_completions_dir/mise"
    fi
    for _comp in "$_bash_completions_dir"/*; do
        [ "$_comp" = "$_bash_completions_dir/mise" ] && continue
        if ! $_bash_supports_usage_completion; then
            case "${_comp##*/}" in
                fnox)
                    continue
                    ;;
            esac
        fi
        IFS= read -r _comp_first_line < "$_comp" || _comp_first_line=
        case "$_comp_first_line" in
            "#compdef"*)
                continue
                ;;
        esac
        [ -r "$_comp" ] && source "$_comp"
    done
    unset _bash_supports_usage_completion _comp _comp_first_line
fi
unset _bash_completions_dir
