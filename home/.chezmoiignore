{{- $ageKey := joinPath .chezmoi.homeDir ".config" "chezmoi" "key.txt" }}
# age 秘密鍵が無い環境では暗号化ファイルをignoreに設定
{{ if not (stat $ageKey) }}
.gitconfig.*
!.gitconfig.github
.ssh/*
!.ssh/config
{{ end }}

# Windows では unix 向け dotfiles (シェル設定・vim・unix ツールの .config) は展開しない。
# git / ssh / starship / コーディングエージェント設定は Windows でも使うため管理を続ける。
{{ if eq .chezmoi.os "windows" }}
.alias
.bash_profile
.zprofile
.tmux.conf
.vimrc
# .vim は .chezmoiexternal.toml の external (dracula テーマ) の展開先。
# external にはディレクトリ単体のパターンだけでは効かないため /** も併記する
.vim
.vim/**
.config/fastfetch
.config/fish
.config/gh
.config/htop
.config/mise
{{ end }}

# .claude / .codex / .gemini / .grok (コーディングエージェント設定) は
# macOS / Linux で skip_cli_tools=true
# Windows で skip_windows_extras=true
# のとき管理対象外にする
{{- $skipCodingAgent := false }}
{{- if hasKey . "skip_cli_tools" }}
{{ $skipCodingAgent = .skip_cli_tools }}
{{- end }}
{{- if hasKey . "skip_windows_extras" }}
{{ $skipCodingAgent = .skip_windows_extras }}
{{- end }}

# Ignore everything under .claude/ by default
.claude/*
{{ if not $skipCodingAgent }}
# Manage only these files
!.claude/CLAUDE.md
# CLAUDE-FABLE-5.md は廃止済み。ignore された target には .chezmoiremove が効かないため、
# 全マシンで削除が済むまで whitelist に残して remove を発火させる (掃除用の暫定エントリ)
!.claude/CLAUDE-FABLE-5.md
!.claude/settings.json
!.claude/settings.fusion.json
!.claude/statusline-command.sh
!.claude/agents
!.claude/skills
!.claude/rules
{{ end }}
# gws-* skills は gws CLI (Homebrew の googleworkspace-cli) 前提のため macOS 以外では展開しない。
# ディレクトリ単体のパターンだけでは中身に効かないことがあるため /** も併記する
{{ if ne .chezmoi.os "darwin" }}
.claude/skills/gws-*
.claude/skills/gws-*/**
{{ end }}
# .claude.json (Claude MCP 設定) も skip_coding_agent=true のとき除外する
{{ if $skipCodingAgent }}
.claude.json
{{ end }}
# Ignore everything under .codex/ by default
.codex/*
{{ if not $skipCodingAgent }}
!.codex/AGENTS.md
!.codex/config.toml
!.codex/fugu.config.toml
!.codex/fusion.config.toml
!.codex/pareto-code.config.toml
!.codex/fugu.json
!.codex/fusion.json
# owl-alpha.json は廃止済み。上の CLAUDE-FABLE-5.md と同じく .chezmoiremove 発火用の暫定エントリ
!.codex/owl-alpha.json
!.codex/pareto-code.json
!.codex/.env
!.codex/agents
!.codex/rules
{{ end }}
# Ignore everything under .gemini/ by default
.gemini/*
{{ if not $skipCodingAgent }}
!.gemini/settings.json
!.gemini/.env
!.gemini/antigravity-cli
!.gemini/antigravity-cli/settings.json
!.gemini/config
!.gemini/config/AGENTS.md
!.gemini/config/mcp_config.json
!.gemini/config/agents
!.gemini/config/agents/**
!.gemini/config/skills
!.gemini/config/skills/**
{{ end }}
# Ignore everything under .grok/ by default (auth・sessions・logs 等のランタイム状態を除外)
.grok/*
{{ if not $skipCodingAgent }}
!.grok/AGENTS.md
!.grok/config.toml
!.grok/skills
{{ end }}
