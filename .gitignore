!.gitattributes
!.pre-commit-config.yaml
!_typos.toml
!.github
!.github/**

# --- Docker / Cloud Build ---
!docker
!docker/Dockerfile.alpine
!docker/Dockerfile.debian
!.dockerignore
!.gcloudignore
!cloudbuild.yaml
!Makefile

# --- ドキュメント ---
!README.md
!CLAUDE.md
!AGENTS.md

# --- chezmoi 本体 ---
!.chezmoiroot
!home
!home/**

# --- インストールスクリプト ---
!install
!install/**

# --- ユーティリティスクリプト ---
!bin
!bin/**

# --- アプリケーション設定 ---
