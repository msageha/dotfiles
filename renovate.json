{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests",
    ":enablePreCommit"
  ],
  "timezone": "Asia/Tokyo",
  "schedule": [
    "* 5 * * *"
  ],
  "separateMajorMinor": true,
  "lockFileMaintenance": {
    "enabled": true
  },
  "minimumReleaseAge": "7 days",
  "customDatasources": {
    "onepassword-cli": {
      "defaultRegistryUrlTemplate": "https://app-updates.agilebits.com/product_history/CLI2",
      "format": "html"
    }
  },
  "packageRules": [
    {
      "description": "PR の乱立を防ぐため、major 以外 (minor/patch/pin/digest) の更新は manager・エコシステム横断で 1 つの PR に集約する。major は separateMajorMinor により分離され、グルーピングせず個別 PR で人手レビューする",
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin",
        "digest",
        "pinDigest"
      ],
      "groupName": "all non-major dependencies",
      "groupSlug": "all-minor-patch"
    },
    {
      "description": "patch/minor は minimumReleaseAge (7日) 経過後、CI green を条件に自動マージする。major は供給網攻撃対策の猶予期間だけでは不十分なため対象外とし、人手レビューを必須とする",
      "matchUpdateTypes": [
        "patch",
        "minor"
      ],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "matchDatasources": [
        "custom.onepassword-cli"
      ],
      "extractVersion": "op_[^/]+_v(?<version>\\d+\\.\\d+\\.\\d+)\\.zip$",
      "versioning": "semver"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "workflow の container.image (digest pin + バージョンコメント) を docker datasource で更新する。ネイティブのgithub-actions managerはdigestのみ追従し、末尾のバージョンコメントを更新しないため必要",
      "managerFilePatterns": [
        "/^\\.github/workflows/.+\\.ya?ml$/"
      ],
      "matchStrings": [
        "image:\\s+(?<depName>[a-z0-9./_-]+)@(?<currentDigest>sha256:[a-f0-9]{64})\\s+#\\s+(?<currentValue>v?\\d+\\.\\d+\\.\\d+)"
      ],
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "dprint.json の公式プラグイン (dprint/dprint-plugin-*) の WASM URL を更新する。@ 以降の sha256 checksum は github-release-attachments datasource が release asset (plugin.wasm) の実ハッシュ照合で追従させる",
      "managerFilePatterns": [
        "/(^|/)dprint\\.json$/"
      ],
      "matchStrings": [
        "https://plugins\\.dprint\\.dev/(?<depName>[a-z0-9-]+)-(?<currentValue>\\d+\\.\\d+\\.\\d+)\\.wasm(?:@(?<currentDigest>[a-f0-9]{64}))?"
      ],
      "datasourceTemplate": "github-release-attachments",
      "packageNameTemplate": "dprint/dprint-plugin-{{depName}}",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "description": "dprint.json の g-plane プラグインの WASM URL を更新する (tag は v prefix 付きなので currentValue に含めて照合する)",
      "managerFilePatterns": [
        "/(^|/)dprint\\.json$/"
      ],
      "matchStrings": [
        "https://plugins\\.dprint\\.dev/g-plane/(?<depName>[a-z0-9_-]+)-(?<currentValue>v\\d+\\.\\d+\\.\\d+)\\.wasm(?:@(?<currentDigest>[a-f0-9]{64}))?"
      ],
      "datasourceTemplate": "github-release-attachments",
      "packageNameTemplate": "g-plane/{{depName}}",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.github/workflows/docker-image-cd\\.yaml$/"
      ],
      "matchStrings": [
        "base: (?<depName>[^:]+):(?<currentValue>[^\\s]+)\\n"
      ],
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^mise\\.toml$/",
        "/^home/dot_config/mise/config\\.toml\\.tmpl$/"
      ],
      "matchStrings": [
        "op = \"(?<currentValue>[^\"]+)\"\\n"
      ],
      "depNameTemplate": "1password-cli",
      "datasourceTemplate": "custom.onepassword-cli"
    },
